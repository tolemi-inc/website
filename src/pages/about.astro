---
import Base from "../layouts/Base.astro";
import PageHero from "../components/blocks/PageHero.astro";
import CallToAction from "../components/blocks/CallToAction.astro";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Markdoc from '@markdoc/markdoc';

export const prerender = true;

const reader = createReader(process.cwd(), keystaticConfig);
const aboutData = await reader.singletons.aboutPage.read();
if (!aboutData) throw new Error('About page data not found');

const historyBody = await aboutData.historyBody();
const historyHtml = Markdoc.renderers.html(Markdoc.transform(historyBody.node));
---

<Base title={aboutData.title}>
  <PageHero headline={aboutData.headline} subheadline={aboutData.subheadline} />

  <section class="py-16 md:py-20 px-6">
    <div class="max-w-3xl mx-auto reveal">
      {aboutData.historyHeading && <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-6">{aboutData.historyHeading}</h2>}
      <div class="prose prose-lg text-text-secondary">
        <Fragment set:html={historyHtml} />
      </div>
    </div>
  </section>

  {aboutData.milestones && aboutData.milestones.length > 0 && (
    <section class="py-16 md:py-20 px-6">
      <div class="max-w-3xl mx-auto reveal">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-10">Milestones</h2>
        <div class="relative border-l-2 border-tolemi-green/20 pl-8 flex flex-col gap-10">
          {aboutData.milestones.map((m) => (
            <div class="relative">
              <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-tolemi-green border-4 border-white"></div>
              <span class="text-sm font-bold text-tolemi-green">{m.year}</span>
              <p class="text-text-secondary mt-1 leading-relaxed">{m.event}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CallToAction
    heading="Ready to Transform Your City's Data?"
    text="Join the growing number of cities using Tolemi to make smarter decisions."
    buttonText="Get a Demo"
    buttonLink="#contact"
  />
</Base>
