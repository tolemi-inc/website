---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/blocks/PageHero.astro";
import CrossLinkCards from "../../components/blocks/CrossLinkCards.astro";
import CallToAction from "../../components/blocks/CallToAction.astro";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import Markdoc from '@markdoc/markdoc';

export const prerender = true;

const reader = createReader(process.cwd(), keystaticConfig);
const allSolutions = await reader.collections.solutions.all();

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const slugs = await reader.collections.solutions.list();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const solution = await reader.collections.solutions.read(slug!);
if (!solution) throw new Error(`Solution not found: ${slug}`);

const bodyHtml = Markdoc.renderers.html(Markdoc.transform(solution.body.node));
const otherSolutions = allSolutions.filter((s) => s.slug !== slug);
---

<Base title={solution.title}>
  <PageHero headline={solution.headline} subheadline={solution.subheadline} />

  <section class="py-16 md:py-20 px-6">
    <div class="max-w-3xl mx-auto reveal prose prose-lg text-text-secondary">
      <Fragment set:html={bodyHtml} />
    </div>
  </section>

  {solution.features && solution.features.length > 0 && (
    <section class="py-16 md:py-20 px-6">
      <div class="max-w-5xl mx-auto reveal">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-10 text-center">Key Features</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {solution.features.map((f) => (
            <div class="bg-white rounded-2xl border border-black/[0.06] p-8">
              <h3 class="font-heading text-lg font-semibold text-text-primary mb-2">{f.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CrossLinkCards
    heading="Other Solutions"
    basePath="/solutions"
    items={otherSolutions.map((s) => ({ title: s.entry.title, slug: s.slug, subheadline: s.entry.subheadline }))}
  />

  <CallToAction
    heading="Ready to Get Started?"
    text="See how Tolemi can help your city with a personalized demo."
    buttonText="Get a Demo"
    buttonLink="#contact"
  />
</Base>
