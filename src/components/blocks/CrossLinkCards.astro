---
interface CardItem {
  title: string;
  slug: string;
  subheadline?: string;
}

interface Props {
  heading?: string;
  basePath: string;
  items: CardItem[];
}

const { heading = "Explore More", basePath, items } = Astro.props;
---

<section class="py-16 md:py-20 px-6 bg-surface-muted/50">
  <div class="max-w-6xl mx-auto reveal">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-10 text-center">{heading}</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item) => (
        <a
          href={`${basePath}/${item.slug}`}
          class="group block bg-white rounded-2xl border border-black/[0.06] p-8 hover:shadow-lg hover:shadow-black/[0.06] hover:border-tolemi-green/20 transition-all duration-300"
        >
          <h3 class="font-heading text-xl font-semibold text-text-primary mb-3 group-hover:text-tolemi-green transition-colors">
            {item.title}
          </h3>
          {item.subheadline && (
            <p class="text-text-secondary text-sm leading-relaxed">{item.subheadline}</p>
          )}
          <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-tolemi-green">
            Learn more
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
