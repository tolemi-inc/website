---
interface Props {
  heading: string;
  text?: string;
  buttonText?: string;
  buttonLink?: string;
}

const { heading, text, buttonText, buttonLink } = Astro.props;
---

<section id="contact" class="relative py-24 md:py-32 px-6 overflow-hidden">
  <!-- Full-bleed gradient background with brand colors -->
  <div class="absolute inset-0 bg-gradient-to-br from-tolemi-green-800 via-tolemi-green-700 to-tolemi-green-900"></div>

  <!-- Color accents — more vivid -->
  <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-tolemi-sky/20 blur-[120px]"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/2 bg-tolemi-yellow/15 blur-[120px]"></div>
  <div class="absolute top-1/3 left-1/4 w-1/4 h-1/3 bg-tolemi-red/10 blur-[100px]"></div>

  <!-- Map background -->
  <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <!-- Street grid -->
    <g opacity="0.06" stroke="white" stroke-width="1">
      <line x1="100" y1="100" x2="1100" y2="100"/>
      <line x1="80" y1="200" x2="1120" y2="200"/>
      <line x1="100" y1="300" x2="1100" y2="300"/>
      <line x1="120" y1="400" x2="1080" y2="400"/>
      <line x1="100" y1="500" x2="1100" y2="500"/>
      <line x1="200" y1="50" x2="200" y2="550"/>
      <line x1="400" y1="50" x2="400" y2="550"/>
      <line x1="600" y1="50" x2="600" y2="550"/>
      <line x1="800" y1="50" x2="800" y2="550"/>
      <line x1="1000" y1="50" x2="1000" y2="550"/>
      <line x1="100" y1="80" x2="1100" y2="520" stroke-width="1.5"/>
    </g>
    <!-- City blocks -->
    <g opacity="0.04" fill="white">
      <rect x="210" y="110" width="180" height="80" rx="2"/>
      <rect x="410" y="110" width="180" height="80" rx="2"/>
      <rect x="610" y="110" width="180" height="80" rx="2"/>
      <rect x="210" y="210" width="180" height="80" rx="2"/>
      <rect x="410" y="210" width="180" height="80" rx="2"/>
      <rect x="610" y="210" width="180" height="80" rx="2"/>
      <rect x="810" y="210" width="180" height="80" rx="2"/>
      <rect x="210" y="310" width="180" height="80" rx="2"/>
      <rect x="410" y="310" width="180" height="80" rx="2"/>
      <rect x="610" y="310" width="180" height="80" rx="2"/>
      <rect x="810" y="310" width="180" height="80" rx="2"/>
      <rect x="410" y="410" width="180" height="80" rx="2"/>
      <rect x="610" y="410" width="180" height="80" rx="2"/>
    </g>
    <!-- Colored data pins -->
    <circle cx="300" cy="150" r="6" fill="#4CD5FF" opacity="0.15"/>
    <circle cx="500" cy="250" r="8" fill="#FFCB1B" opacity="0.12"/>
    <circle cx="700" cy="350" r="7" fill="#FF0025" opacity="0.12"/>
    <circle cx="900" cy="250" r="5" fill="#37A04F" opacity="0.15"/>
    <circle cx="450" cy="450" r="6" fill="#4CD5FF" opacity="0.1"/>
  </svg>

  <div class="relative z-10 max-w-3xl mx-auto text-center reveal">
    <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">{heading}</h2>
    {text && <p class="text-lg text-white/70 mb-10 leading-relaxed">{text}</p>}
    {buttonText && (
      <a
        href={buttonLink || "#"}
        class="inline-flex items-center gap-2 bg-white text-tolemi-green-800 font-semibold px-8 py-4 rounded-full hover:bg-tolemi-light transition-all hover:shadow-xl hover:shadow-black/10 text-base"
      >
        {buttonText}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    )}
  </div>

  <!-- Bottom brand bar -->
  <div class="absolute bottom-0 left-0 w-full h-1 flex">
    <div class="flex-1 bg-tolemi-red"></div>
    <div class="flex-1 bg-tolemi-yellow"></div>
    <div class="flex-1 bg-tolemi-sky"></div>
    <div class="flex-1 bg-tolemi-green"></div>
  </div>
</section>
