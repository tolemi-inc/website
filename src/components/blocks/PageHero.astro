---
interface Props {
  headline: string;
  subheadline?: string;
}

const { headline, subheadline } = Astro.props;
---

<section class="relative pt-44 pb-20 md:pt-52 md:pb-28 px-6 overflow-hidden z-0">
  <div class="absolute inset-0 bg-gradient-to-br from-surface via-white to-tolemi-green/[0.03]"></div>
  <div class="relative max-w-4xl mx-auto text-center reveal">
    <h1 class="font-heading text-4xl md:text-6xl font-bold text-text-primary mb-6">{headline}</h1>
    {subheadline && (
      <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">{subheadline}</p>
    )}
  </div>
</section>
