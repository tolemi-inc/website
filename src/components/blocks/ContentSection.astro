---
interface Props {
  heading?: string;
  body?: string;
}

const { heading, body } = Astro.props;
---

<section class="py-16 md:py-20 px-6">
  <div class="max-w-3xl mx-auto reveal">
    {heading && <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary mb-6">{heading}</h2>}
    {body && <p class="text-text-secondary text-lg leading-relaxed whitespace-pre-line">{body}</p>}
    <slot />
  </div>
</section>
