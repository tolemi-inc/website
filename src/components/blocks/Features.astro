---
interface FeatureItem {
  title: string;
  description?: string;
  icon?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  items?: FeatureItem[];
}

const { heading, subheading, items = [] } = Astro.props;
---

<section id="features" class="relative">
  {/* Section header */}
  {heading && (
    <div class="py-16 md:py-20 px-6 bg-surface">
      <div class="max-w-7xl mx-auto reveal">
        <h2 class="font-heading text-[2.5rem] md:text-5xl font-bold text-text-primary tracking-tight mb-5">
          {heading}
        </h2>
        {subheading && (
          <p class="text-base text-text-secondary max-w-2xl leading-relaxed">{subheading}</p>
        )}
      </div>
    </div>
  )}

  {/* Feature 1: Parcel-Level Precision — slides up, UI from left */}
  {items[0] && (
    <div class="feature-slide relative overflow-hidden bg-gradient-to-br from-tolemi-sky-50 via-white to-tolemi-sky-100/50">
      <div class="max-w-7xl mx-auto px-6 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
        <div class="feature-slide-left">
          <div class="w-3 h-3 rounded-full bg-tolemi-sky mb-5"></div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-text-primary mb-3">{items[0].title}</h3>
          {items[0].description && (
            <p class="text-base text-text-secondary leading-relaxed max-w-sm">{items[0].description}</p>
          )}
        </div>
        <div class="feature-slide-right w-full max-w-lg">
          {/* Location UI Component Mockup */}
          <div class="bg-surface rounded-xl shadow-lg border border-text-muted/10 overflow-hidden max-w-md mx-auto">
            {/* Header */}
            <div class="px-5 py-3 border-b border-text-muted/10 flex items-center gap-2">
              <svg class="w-4 h-4 text-tolemi-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span class="font-heading text-sm font-semibold text-text-primary">Location</span>
            </div>
            <div class="flex">
              {/* Left: Property details */}
              <div class="flex-1 px-5 py-4 text-xs space-y-3">
                <div>
                  <span class="text-text-muted">Map Block</span>
                  <p class="text-text-primary font-medium">3032</p>
                </div>
                <div>
                  <span class="text-text-muted">Planning Districts</span>
                  <p class="text-text-primary font-medium">Central</p>
                </div>
                <div>
                  <span class="text-text-muted">Representative Districts</span>
                  <p class="text-text-primary font-medium text-[11px]">8th Congressional District - US</p>
                  <p class="text-tolemi-sky text-[11px]">Representative: Stephen F. Lynch (D)</p>
                </div>
                <div>
                  <span class="text-text-muted">City Limits</span>
                  <p class="text-text-primary font-medium">City of Boston</p>
                </div>
                <div>
                  <span class="text-text-muted">Fire Districts</span>
                  <p class="text-text-primary font-medium">3</p>
                </div>
                <div>
                  <span class="text-text-muted">ICP Zone</span>
                  <p class="text-text-primary font-medium">Zone A</p>
                </div>
              </div>
              {/* Right: Map */}
              <div class="w-48 relative bg-tolemi-sky/5">
                <svg class="w-full h-full" viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg">
                  <rect width="200" height="280" fill="#e8f4e8" opacity="0.3"/>
                  <path d="M140,0 L200,0 L200,120 Q180,100 160,110 Q140,120 140,80 Z" fill="#b3d9f2" opacity="0.4"/>
                  <path d="M160,140 L200,130 L200,200 L170,190 Z" fill="#b3d9f2" opacity="0.3"/>
                  <g stroke="#ccc" stroke-width="1.5" opacity="0.5">
                    <line x1="0" y1="60" x2="200" y2="60"/>
                    <line x1="0" y1="120" x2="140" y2="120"/>
                    <line x1="0" y1="180" x2="160" y2="180"/>
                    <line x1="0" y1="240" x2="200" y2="240"/>
                    <line x1="40" y1="0" x2="40" y2="280"/>
                    <line x1="90" y1="0" x2="90" y2="280"/>
                    <line x1="130" y1="0" x2="130" y2="280"/>
                    <path d="M0,200 Q60,160 130,120" fill="none" stroke-width="2"/>
                  </g>
                  <g fill="#ddd" opacity="0.3">
                    <rect x="5" y="65" width="30" height="50" rx="1"/>
                    <rect x="45" y="65" width="40" height="50" rx="1"/>
                    <rect x="95" y="65" width="30" height="50" rx="1"/>
                    <rect x="5" y="125" width="30" height="50" rx="1"/>
                    <rect x="45" y="125" width="40" height="50" rx="1"/>
                    <rect x="95" y="125" width="30" height="50" rx="1"/>
                  </g>
                  <text x="155" y="170" fill="#666" font-size="6" font-family="Inter, sans-serif" opacity="0.5">Pilot House Park</text>
                  <text x="60" y="210" fill="#666" font-size="5" font-family="Inter, sans-serif" opacity="0.4">FLEET ST</text>
                  <g transform="translate(95, 145)">
                    <circle cx="0" cy="0" r="8" fill="#4CD5FF" opacity="0.2"/>
                    <circle cx="0" cy="0" r="4" fill="#4CD5FF"/>
                  </g>
                </svg>
                <div class="absolute top-2 right-2 flex flex-col gap-1">
                  <div class="w-6 h-6 bg-surface rounded shadow-sm flex items-center justify-center text-text-muted text-xs font-bold">+</div>
                  <div class="w-6 h-6 bg-surface rounded shadow-sm flex items-center justify-center text-text-muted text-xs font-bold">−</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-tolemi-sky/30 to-transparent"></div>
    </div>
  )}

  {/* Feature 2: Complete Ownership History — slides up, UI from right */}
  {items[1] && (
    <div class="feature-slide relative overflow-hidden bg-gradient-to-bl from-tolemi-red-50 via-white to-tolemi-red-100/30">
      <div class="max-w-7xl mx-auto px-6 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
        <div class="feature-slide-right md:order-2">
          <div class="w-3 h-3 rounded-full bg-tolemi-red mb-5"></div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-text-primary mb-3">{items[1].title}</h3>
          {items[1].description && (
            <p class="text-base text-text-secondary leading-relaxed max-w-sm">{items[1].description}</p>
          )}
        </div>
        <div class="feature-slide-left w-full max-w-sm md:order-1">
          {/* Owner Timeline UI Component Mockup */}
          <div class="bg-surface rounded-xl shadow-lg border border-text-muted/10 overflow-hidden max-w-sm mx-auto">
            {/* Current Owner */}
            <div class="px-5 pt-4 pb-2">
              <span class="font-heading text-xs font-bold text-text-primary tracking-wide">Owners (1)</span>
            </div>
            <div class="mx-4 mb-4 rounded-lg border border-text-muted/10 p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-5 h-5 rounded border border-text-muted/20"></div>
                <span class="font-heading text-sm font-bold text-tolemi-sky">PDJM LLC</span>
              </div>
              <div class="flex items-start gap-2 mb-3 ml-1">
                <svg class="w-3.5 h-3.5 text-tolemi-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                <div class="text-xs text-text-primary leading-relaxed">
                  9 MT VERNON ST STE B,<br/>WINCHESTER, MA, 01890
                </div>
              </div>
              <div class="space-y-1.5 mb-3">
                <div class="text-xs text-text-secondary bg-surface-secondary rounded px-3 py-1.5">+ Linked (4)</div>
                <div class="text-xs text-text-secondary bg-surface-secondary rounded px-3 py-1.5">+ Other Properties (12)</div>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <span class="text-tolemi-red italic">03/28/2018</span>
                <div class="flex-1 h-0.5 bg-tolemi-sky rounded"></div>
                <span class="text-text-secondary italic">Present</span>
                <div class="w-4 h-4 rounded-full border border-text-muted/30 flex items-center justify-center">
                  <span class="text-text-muted text-[8px]">i</span>
                </div>
              </div>
            </div>

            {/* Previous Owners */}
            <div class="px-5 pt-2 pb-2 border-t border-text-muted/10">
              <span class="font-heading text-xs font-bold text-text-muted tracking-wide">Previous Owners (2)</span>
            </div>
            <div class="mx-4 mb-3 rounded-lg border border-text-muted/10 p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-5 h-5 rounded border border-text-muted/20"></div>
                <span class="font-heading text-sm font-bold text-tolemi-sky">ONE FAIRFIELD PL LLC</span>
              </div>
              <div class="flex items-start gap-2 mb-3 ml-1">
                <svg class="w-3.5 h-3.5 text-tolemi-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                <div class="text-xs text-text-primary leading-relaxed">
                  283 CAUSEWAY ST,<br/>BOSTON, MA, 02114
                </div>
              </div>
              <div class="text-xs text-text-secondary bg-surface-secondary rounded px-3 py-1.5 mb-3">+ Other Properties (0)</div>
              <div class="flex items-center gap-2 text-xs">
                <span class="text-tolemi-red italic">01/01/2014</span>
                <div class="flex-1 h-0.5 bg-tolemi-sky rounded"></div>
                <span class="text-text-muted italic">03/28/2018</span>
                <div class="w-4 h-4 rounded-full border border-text-muted/30 flex items-center justify-center">
                  <span class="text-text-muted text-[8px]">i</span>
                </div>
              </div>
            </div>
            <div class="mx-4 mb-4 rounded-lg border border-text-muted/10 p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-5 h-5 rounded border border-text-muted/20"></div>
                <span class="font-heading text-sm font-bold text-tolemi-sky">1 Fairfield Place LLC</span>
              </div>
              <div class="text-xs text-text-secondary bg-surface-secondary rounded px-3 py-1.5 mb-3">+ Other Properties (0)</div>
              <div class="flex items-center gap-2 text-xs">
                <span class="text-tolemi-red italic">05/28/2008</span>
                <div class="flex-1 h-0.5 bg-tolemi-sky rounded"></div>
                <span class="text-text-muted italic">01/01/2014</span>
                <div class="w-4 h-4 rounded-full border border-text-muted/30 flex items-center justify-center">
                  <span class="text-text-muted text-[8px]">i</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-tolemi-red/30 to-transparent"></div>
    </div>
  )}

  {/* Feature 3: Assessment Intelligence — slides up, UI from left */}
  {items[2] && (
    <div class="feature-slide relative overflow-hidden bg-gradient-to-br from-tolemi-yellow-50 via-white to-tolemi-yellow-100/30">
      <div class="max-w-7xl mx-auto px-6 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
        <div class="feature-slide-left">
          <div class="w-3 h-3 rounded-full bg-tolemi-yellow mb-5"></div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-text-primary mb-3">{items[2].title}</h3>
          {items[2].description && (
            <p class="text-base text-text-secondary leading-relaxed max-w-sm">{items[2].description}</p>
          )}
        </div>
        <div class="feature-slide-right w-full max-w-md">
          {/* Assessments + Attributes UI Component Mockup */}
          <div class="bg-surface rounded-xl shadow-lg border border-text-muted/10 overflow-hidden max-w-md mx-auto">
            {/* Assessments Chart */}
            <div class="px-5 pt-4 pb-2">
              <span class="font-heading text-xs font-bold text-text-primary tracking-wide">Assessments</span>
            </div>
            <div class="px-5 pb-3">
              <svg viewBox="0 0 340 120" class="w-full" xmlns="http://www.w3.org/2000/svg">
                <text x="0" y="15" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">$600k</text>
                <text x="0" y="40" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">$400k</text>
                <text x="0" y="65" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">$200k</text>
                <text x="0" y="90" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">$0</text>
                <g stroke="#9ca3af" stroke-width="0.3" opacity="0.2">
                  <line x1="30" y1="12" x2="340" y2="12"/>
                  <line x1="30" y1="37" x2="340" y2="37"/>
                  <line x1="30" y1="62" x2="340" y2="62"/>
                  <line x1="30" y1="87" x2="340" y2="87"/>
                </g>
                <path d="M30,87 L75,85 L120,80 L165,75 L210,60 L255,45 L300,30 L340,20 L340,87 Z" fill="#FFCB1B" opacity="0.15"/>
                <path d="M30,87 L75,86 L120,84 L165,82 L210,75 L255,65 L300,55 L340,45 L340,87 Z" fill="#37A04F" opacity="0.1"/>
                <polyline points="30,87 75,85 120,80 165,75 210,60 255,45 300,30 340,20" fill="none" stroke="#FFCB1B" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
                <circle cx="210" cy="60" r="2.5" fill="#FFCB1B" opacity="0.8"/>
                <circle cx="255" cy="45" r="2.5" fill="#FFCB1B" opacity="0.8"/>
                <circle cx="300" cy="30" r="2.5" fill="#FFCB1B" opacity="0.8"/>
                <circle cx="340" cy="20" r="2.5" fill="#FFCB1B" opacity="0.8"/>
                <text x="30" y="100" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">2015</text>
                <text x="120" y="100" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">2017</text>
                <text x="210" y="100" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">2019</text>
                <text x="300" y="100" fill="currentColor" class="text-text-muted" font-size="7" opacity="0.5">2021</text>
              </svg>
            </div>

            {/* Assessment details */}
            <div class="px-5 pb-4 border-b border-text-muted/10">
              <div class="flex items-center gap-2 mb-3">
                <div class="bg-surface-secondary rounded px-2 py-1 text-xs text-text-secondary">07/01/2025</div>
                <svg class="w-3 h-3 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </div>
              <div class="grid grid-cols-2 gap-y-2 text-xs">
                <span class="text-text-muted">Land Value:</span>
                <span class="text-text-primary font-medium text-right">$0</span>
                <span class="text-text-muted">Improvement Value:</span>
                <span class="text-text-primary font-medium text-right">$586,600</span>
                <span class="text-tolemi-yellow font-semibold">Total Value:</span>
                <span class="text-tolemi-yellow font-bold text-right">$586,600</span>
              </div>
            </div>

            {/* Property Attributes table */}
            <div class="px-5 pt-3 pb-1">
              <span class="font-heading text-xs font-bold text-text-primary tracking-wide">Property Attributes</span>
            </div>
            <div class="px-5 pb-4">
              <table class="w-full text-xs">
                <tbody>
                  <tr class="border-b border-text-muted/5">
                    <td class="py-1.5 text-text-muted">Current Use</td>
                    <td class="py-1.5 text-text-primary text-right font-medium">102 - RESIDENTIAL CONDO</td>
                    <td class="py-1.5 pl-2 w-4"><div class="w-2.5 h-2.5 rounded-full bg-tolemi-yellow"></div></td>
                  </tr>
                  <tr class="border-b border-text-muted/5">
                    <td class="py-1.5 text-text-muted">Property Type</td>
                    <td class="py-1.5 text-text-primary text-right font-medium">Structure</td>
                    <td class="py-1.5 pl-2 w-4"><div class="w-2.5 h-2.5 rounded-full bg-tolemi-sky"></div></td>
                  </tr>
                  <tr class="border-b border-text-muted/5">
                    <td class="py-1.5 text-text-muted">FAR Ratio</td>
                    <td class="py-1.5 text-text-primary text-right font-medium">1</td>
                    <td class="py-1.5 pl-2 w-4"><div class="w-2.5 h-2.5 rounded-full bg-tolemi-yellow"></div></td>
                  </tr>
                  <tr class="border-b border-text-muted/5">
                    <td class="py-1.5 text-text-muted">Land Size</td>
                    <td class="py-1.5 text-text-primary text-right font-medium">0.02 acres</td>
                    <td class="py-1.5 pl-2 w-4"><div class="w-2.5 h-2.5 rounded-full bg-tolemi-red"></div></td>
                  </tr>
                  <tr>
                    <td class="py-1.5 text-text-muted">Total Assessed Value</td>
                    <td class="py-1.5 text-text-primary text-right font-medium">$586,600</td>
                    <td class="py-1.5 pl-2 w-4"><div class="w-2.5 h-2.5 rounded-full bg-tolemi-red"></div></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</section>
