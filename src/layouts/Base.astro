---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import siteData from "../../content/global/site.json";

interface Props {
  title?: string;
}

const { title = siteData.companyName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Raleway:wght@300;400;500;700&family=Montserrat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans text-text-primary bg-surface antialiased">
    <Header companyName={siteData.companyName} nav={siteData.nav} />
    <main>
      <slot />
    </main>
    <Footer footerText={siteData.footerText} socialLinks={siteData.socialLinks} />

    <!-- Global scroll-reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal, .feature-slide, .feature-slide-left, .feature-slide-right').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
